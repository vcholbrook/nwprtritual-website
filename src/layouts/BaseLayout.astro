---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ApplicationModal from '../components/ApplicationModal.astro';

interface Props {
  title?: string;
  description?: string;
  /** Path relative to /public (e.g. "/img/og.jpg") or absolute URL. */
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** Set to false to omit the sticky header (e.g. for a future coming-soon screen). */
  showHeader?: boolean;
  /** Set to false to omit the footer. */
  showFooter?: boolean;
}

const DEFAULT_TITLE = 'NWPRT Ritual';
const DEFAULT_DESCRIPTION =
  'A 4-day immersive wellness retreat in Newport Beach. DNA-driven insights, expert-led pods, coastal activities, and a 90-day personalized roadmap. By application only.';

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage = '/og-nwprt-ritual.jpg',
  ogType = 'website',
  showHeader = true,
  showFooter = true,
} = Astro.props;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.nwprtritual.com';
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const absoluteOg = ogImage.startsWith('http') ? ogImage : `${siteOrigin}${ogImage}`;
const fullTitle = title === DEFAULT_TITLE ? DEFAULT_TITLE : `${title} | ${DEFAULT_TITLE}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/jpeg" sizes="32x32" href="/favicon-32.jpg" />
    <link rel="icon" type="image/jpeg" sizes="256x256" href="/favicon-256.jpg" />
    <link rel="apple-touch-icon" sizes="256x256" href="/favicon-256.jpg" />
    <link rel="canonical" href={canonical} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={DEFAULT_TITLE} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={absoluteOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOg} />
  </head>
  <body class="antialiased min-h-screen flex flex-col overflow-x-hidden">
    {showHeader && <SiteHeader />}
    <main class="flex-grow">
      <slot />
    </main>
    {showFooter && <SiteFooter />}
    <ApplicationModal />

    <script>
      import '../scripts/scroll-reveal.ts';
    </script>
  </body>
</html>
