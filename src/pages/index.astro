---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/sections/Hero.astro';
import WhatIsRitual from '../components/sections/WhatIsRitual.astro';
import Experience from '../components/sections/Experience.astro';
import DeepDive from '../components/sections/DeepDive.astro';
import Agenda from '../components/sections/Agenda.astro';
import Takeaway from '../components/sections/Takeaway.astro';
