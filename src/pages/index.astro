---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';
import AgendaDay, { type ScheduleItem } from '../components/AgendaDay.astro';
import PodCard from '../components/PodCard.astro';
import PricingCard from '../components/PricingCard.astro';

/* ─────────────────────────────────────────────────────────────
 *  Content data — tweak copy here, not inside components.
 * ──────────────────────────────────────────────────────────── */

const HERO_STATS = [
  { label: 'Women', value: '24' },
  { label: 'Duration', value: '4 Days · 3 Nights' },
  { label: 'Investment', value: 'From $4,800' },
  { label: 'Application', value: 'By Selection' },
];

const EXPERIENCE_STATS = [
  { num: '24', label: 'Women · By Application Only' },
  { num: '4', label: 'Days of Transformation' },
  { num: '90', label: 'Day Personalized Roadmap' },
  { num: '1', label: 'Woman at the Center · You' },
];

const THURSDAY: ScheduleItem[] = [
  { time: '12–3PM', session: 'Arrivals & check in — gift bag waiting in room' },
  { time: '1–2:30PM', session: 'Group 1 — pre-selected at application', tag: { label: 'Spa Pass', pod: 'spa' } },
  { time: '3–4PM', session: 'Welcome, meet the group & mocktail' },
  { time: '5–6PM', session: 'Sunset breathwork', tag: { label: 'The Shore', pod: 'shore' } },
  { time: '6–7PM', session: 'Welcome dinner — farm to table, wine available' },
  { time: '7:30–8:30PM', session: "Opening circle — why you're here, no topic off limits" },
];

const FRIDAY: ScheduleItem[] = [
  { time: '6:30–7:30AM', session: 'Morning movement — Fitness Lead', tag: { label: 'The Current', pod: 'current' } },
  { time: '8:45–9:30AM', session: 'Halo Founder — your data decoded', tag: { label: 'The Signal', pod: 'signal' } },
  { time: '9:45–11:15AM', session: 'Pod Rotations — Round 1' },
  { time: '11:30AM–1PM', session: 'Pod Rotations — Round 2' },
  { time: '1–2PM', session: 'Lunch & Learn — Nutrition Lead', tag: { label: 'The Tide', pod: 'tide' } },
  { time: '2–3:30PM', session: 'Pod Rotations — Round 3' },
  { time: '3:30–5PM', session: 'Individual touchpoints + Spa Pass Group 2' },
  { time: '5:30–7PM', session: 'Interactive cooking class — Newport Chef + Nutrition Lead', tag: { label: 'The Current', pod: 'current' } },
  { time: '7–7:30PM', session: 'Dinner — eat what was cooked, wine available' },
  { time: '7:30–8:30PM', session: 'Sound bath — integrate, receive, restore', tag: { label: 'The Shore', pod: 'shore' } },
];

const SATURDAY: ScheduleItem[] = [
  { time: '6:30–7:30AM', session: 'Coastal bike or paddleboard — Fitness Lead', tag: { label: 'The Current', pod: 'current' } },
  { time: '9–10:30AM', session: 'Pod Rotations — Round 4 · Final rotation' },
  { time: '10:30AM–12PM', session: 'Individual touchpoints + Wellness Lounge + Spa Pass Group 3' },
  { time: '12–1PM', session: 'Lunch' },
  { time: '1–1:30PM', session: 'Light walk — on property or coastal' },
  { time: '1:30–3PM', session: 'Group painting with local Newport artist' },
  { time: '3:15–4:15PM', session: 'Guest speaker / educational programming', tag: { label: 'The Tide', pod: 'tide' } },
  { time: '4:15–5:30PM', session: 'Free time — get ready' },
  { time: '5:30–8:30PM', session: 'Yacht dinner — signature Newport evening' },
];

const SUNDAY: ScheduleItem[] = [
  { time: '6:30–7:30AM', session: 'Sunrise walk & gentle yoga — Fitness Lead', tag: { label: 'The Current', pod: 'current' } },
  { time: '7:30–8:30AM', session: 'Coffee & breakfast + Spa Pass Group 4' },
  { time: '8:30–8:45AM', session: 'Short group meditation — opening The Shore' },
  { time: '8:45–9:30AM', session: 'Q&A with experts — open, honest, no topic off limits', tag: { label: 'The Shore', pod: 'shore' } },
  { time: '9:30–10AM', session: 'I Am — personal intention recording exercise' },
  { time: '10–10:30AM', session: 'Letter to your future self — sealed, mailed at 30 days' },
  { time: '10:30AM–12PM', session: 'Send off brunch — 90-day roadmap in hand' },
];

const PODS = [
  { letter: 'A', name: 'The Signal', lead: 'Halo Founder', description: 'DNA & genomic data decoded.' },
  { letter: 'B', name: 'The Tide', lead: 'Affiliated MD', description: 'Bloodwork & hormones reviewed.' },
  { letter: 'C', name: 'The Current', lead: 'Functional Nutritionist', description: 'Smoothies, Fab 4 & hormone nutrition.' },
  { letter: 'D', name: 'The Shore', lead: 'Mind-Body Specialist', description: 'Movement, breathwork & meditation.' },
];

const LEAVE_WITH = [
  { title: '90-Day Roadmap', tag: 'Your personalized plan', body: 'A detailed, actionable plan that guides you through the next 90 days, tailored to your unique biological profile.' },
  { title: 'Personal Hypnosis Audio', tag: 'Deepen your practice', body: 'A guided hypnosis session to help you integrate the insights and practices from the retreat.' },
  { title: 'Future Self Letter', tag: 'A message to your future self', body: "A letter you write to yourself on the last day of the retreat, to be opened 30 days later." },
];

const BRANDS = [
  { title: 'Halo', tag: 'The Science', body: 'Genomics, biomarkers, and wearables blended with functional medicine. Your complete biological picture — decoded, actionable, and finally yours.' },
  { title: 'NWPRT', tag: 'The Lifestyle', body: 'The brand that is Newport Beach. In the gift bag, on the morning walk, at the yacht dinner. The visual identity of a life well lived.' },
  { title: 'Ritual', tag: 'The Container', body: "Where Halo's science and Newport's lifestyle collide. Four days that become the foundation for everything that follows." },
];

const JOURNEY = [
  { name: 'Newport Beach', sub: 'The Foundation' },
  { name: 'Napa / La Jolla', sub: 'The Reset' },
  { name: 'Croatia', sub: 'The Odyssey' },
];

const NEWPORT_CARDS = [
  { title: 'Newport Harbor', body: 'One of the finest small boat harbors in the world. 9,000+ vessels. The yacht dinner backdrop that makes Saturday evening unforgettable.' },
  { title: 'Crystal Cove', body: 'Historic 1920s coastal cottages, 3.2 miles of natural seashore. Once the Hollywood elite getaway. Still magical.' },
  { title: 'Pacific Coast Highway', body: 'The iconic coastal ride. Saturday morning on bikes. Salt air, ocean views, 24 women finding their current.' },
  { title: 'Fashion Island', body: "Open-air luxury at the heart of Newport. The backdrop for the lifestyle you've earned and are learning to inhabit fully." },
  { title: 'Balboa Island', body: '2.6 miles of waterfront charm. Boutiques, dining, the ferry. The kind of afternoon that makes everything feel possible.' },
  { title: 'The Pacific', body: 'Dolphins. Gray whales. 8 miles of coastline. A constant reminder: tides shift. So do we.' },
];

const DOUBLE_INCLUSIONS = [
  'Full retreat program',
  'Shared private room · 3 nights',
  'All meals + wine at dinners',
  'Yacht dinner Saturday',
  'All pod sessions & expert access',
  'Curated gift bag',
  'Spa pass (1 session)',
  '90-day roadmap',
  'Personal hypnosis audio',
];

const SINGLE_INCLUSIONS = [
  'Full retreat program',
  'Private room · 3 nights',
  'All meals + wine at dinners',
  'Yacht dinner Saturday',
  'All pod sessions & expert access',
  'Curated gift bag + morning ritual kit',
  'Pre-retreat prep box',
  'Spa pass (1 session)',
  '90-day personalized roadmap',
  'Personal hypnosis audio',
  'Future self letter at 30 days',
];

const PRIVATE_INCLUSIONS = [
  'Entire retreat exclusively yours',
  'Custom programming for your group',
  'All single occupancy inclusions',
  'Corporate teams, friend groups, wellness communities',
  'You set the price for your group',
];

/* Hero background photo — replace with real artwork when delivered. */
const HERO_BG = 'https://images.unsplash.com/photo-1586304785796-234dfa36da73?auto=format&fit=crop&w=1920&q=80';
---

<BaseLayout
  title="NWPRT Ritual — Where Newport Meets Your Biology"
  description="A 4-day immersive wellness retreat in Newport Beach. DNA-driven insights, expert-led pods, coastal activities, and a 90-day personalized roadmap. 24 women, by application only."
>
  {/* ══════════════════════════════════════════════════════════
       1. HERO
       ═════════════════════════════════════════════════════════ */}
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-nwprt-navy text-nwprt-cream">
    <div class="absolute inset-0">
      <img
        src={HERO_BG}
        alt="Newport Beach Harbor at sunset"
        class="w-full h-full object-cover opacity-35"
        loading="eager"
      />
    </div>
    <div class="absolute inset-0 bg-nwprt-navy/75"></div>

    <Container size="md" class="relative z-10 text-center fade-in">
      {/* Yellow moment #1 — signature hero eyebrow. */}
      <div class="caption text-nwprt-yellow mb-8">Newport Beach, California</div>

      <h1 class="display text-6xl md:text-8xl lg:text-[9rem] leading-none tracking-tight">
        NWPRT<span class="accent-italic text-nwprt-yellow align-super text-xl md:text-2xl ml-1">&trade;</span>
      </h1>
      <div class="accent-italic text-3xl md:text-5xl text-nwprt-cream/90 mt-2 mb-10">Ritual</div>

      <div class="rule-yellow mx-auto mb-12"></div>

      {/* Flat stats band — no backdrop-blur, no translucency. */}
      <div class="border-y border-nwprt-cream/20 py-6 px-4 md:px-8 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-12">
        {HERO_STATS.map((stat) => (
          <div class="text-center">
            <div class="caption text-nwprt-cream/60 mb-2">{stat.label}</div>
            <div class="display text-lg md:text-xl text-nwprt-cream">{stat.value}</div>
          </div>
        ))}
      </div>

      <p class="accent-italic text-xl md:text-2xl text-nwprt-cream/70 max-w-lg mx-auto">
        Where Newport meets your biology.
      </p>
    </Container>
  </section>

  {/* ══════════════════════════════════════════════════════════
       2. THE EXPERIENCE
       ═════════════════════════════════════════════════════════ */}
  <Section tone="navy" spacing="lg">
    <Container size="md">
      <div class="scroll-reveal">
        <div class="caption text-nwprt-cream/50 mb-3">Chapter one</div>
        <h2 class="display text-4xl md:text-6xl mb-6">The Experience</h2>
        <div class="rule bg-nwprt-cream mb-10 opacity-40"></div>

        <div class="space-y-6 text-lg md:text-xl leading-relaxed text-nwprt-cream/85">
          <p>
            You arrive on a Thursday afternoon and something happens the moment you step out of the car.
            The salt air, the light, the sound of the ocean. And for the first time in longer than you can
            remember, you exhale. This isn&rsquo;t a conference, it isn&rsquo;t a spa day, and it isn&rsquo;t
            another thing on your to-do list.
          </p>
          <p>
            For four days, the only person you are responsible for is yourself. What makes this different
            is that everything &mdash; the advice, the experts, the movement, the food, the recommendations
            you leave with &mdash; is tailored specifically to <span class="accent-italic text-nwprt-cream">you</span>.
            Your DNA. Your bloodwork. Your wearable data.
          </p>
          <p>
            Newport Beach isn&rsquo;t just a backdrop. It&rsquo;s intentional. You leave Sunday with answers
            you didn&rsquo;t have before, a body that feels seen, and a group of women you will keep for the
            rest of your life.
          </p>
        </div>
      </div>

      <div class="scroll-reveal mt-16 grid grid-cols-1 sm:grid-cols-2 gap-8">
        {EXPERIENCE_STATS.map((stat) => (
          <div class="border-l-2 border-nwprt-cream/30 pl-5">
            <div class="display text-5xl md:text-6xl text-nwprt-cream mb-2">{stat.num}</div>
            <div class="caption text-nwprt-cream/60">{stat.label}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       3. WHAT IS NWPRT RITUAL
       ═════════════════════════════════════════════════════════ */}
  <Section tone="cream" spacing="lg">
    <Container size="md">
      <div class="scroll-reveal">
        <div class="caption text-nwprt-navy/50 mb-3">The premise</div>
        <h2 class="display text-4xl md:text-6xl text-nwprt-navy mb-6">What is NWPRT Ritual?</h2>
        <div class="rule bg-nwprt-navy mb-10 opacity-40"></div>

        <div class="space-y-6 text-lg md:text-xl leading-relaxed text-nwprt-navy/80">
          <p>
            NWPRT Ritual is a 4-day immersive wellness retreat in Newport Beach, California, designed
            exclusively for women who are ready to understand their bodies at the deepest biological level.
          </p>
          <p>
            This isn&rsquo;t a spa weekend or a conference. It&rsquo;s a full reset, grounded in your DNA,
            your bloodwork, your wearable data, and the expertise of functional medicine practitioners who
            actually listen.
          </p>
          <p>
            You&rsquo;ll rotate through four expert-led pods, participate in coastal activities that restore
            your nervous system, and leave Sunday with a 90-day personalized roadmap that finally makes
            sense for <span class="accent-italic">your</span> body.
          </p>
          <p class="accent-italic text-nwprt-navy/90">
            Limited to 24 women. By application only.
          </p>
        </div>
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       4. THIS IS PERSONAL
       ═════════════════════════════════════════════════════════ */}
  <Section tone="navy" spacing="lg">
    <Container size="md" class="text-center">
      <div class="scroll-reveal">
        <div class="caption text-nwprt-cream/50 mb-3">Chapter two</div>
        <h2 class="display text-4xl md:text-6xl mb-14">This Is Personal</h2>

        <div class="text-left space-y-8 text-lg leading-relaxed text-nwprt-cream/85 max-w-2xl mx-auto">
          <p>
            You have felt it. The subtle shifts that showed up quietly and then all at once. The energy that
            used to be there. The sleep that is not quite right. The sense that your body is changing and
            nobody around you seems to have real answers, just general advice that was never designed for you
            specifically.
          </p>

          <p class="accent-italic text-2xl md:text-3xl text-nwprt-cream text-center">
            That changes here.
          </p>

          <p>
            NWPRT Ritual was built on a simple but powerful idea: that every woman deserves to understand her
            own biology. Not a textbook version of what women your age typically experience. Not a one-size-fits-all
            supplement protocol or a generic nutrition plan. Your actual data. Your specific hormones. Your unique
            genetic blueprint.
          </p>

          <p class="accent-italic text-xl text-nwprt-cream/70 text-center pt-2">
            This is not wellness in general. This is wellness for women in this season of life.
          </p>
        </div>

        <div class="rule bg-nwprt-cream opacity-40 mx-auto mt-16"></div>
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       5. THE AGENDA
       ═════════════════════════════════════════════════════════ */}
  <Section tone="cream" spacing="lg">
    <Container>
      <div class="scroll-reveal mb-12">
        <div class="caption text-nwprt-navy/50 mb-3">The four days</div>
        <h2 class="display text-4xl md:text-6xl text-nwprt-navy mb-6">The Agenda</h2>
        <div class="rule bg-nwprt-navy mb-2 opacity-40"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
        <div class="space-y-12">
          <AgendaDay day="Thursday" subtitle="Arrive & exhale" items={THURSDAY} />
          <AgendaDay day="Saturday" subtitle="Experience Newport" items={SATURDAY} />
        </div>
        <div class="space-y-12">
          <AgendaDay day="Friday" subtitle="Go deep" items={FRIDAY} />
          <AgendaDay day="Sunday" subtitle="Integrate & send off" items={SUNDAY} />
        </div>
      </div>

      {/* Pods */}
      <div class="scroll-reveal mt-20 pt-12 border-t border-nwprt-navy/15">
        <div class="caption text-nwprt-navy mb-6">
          The Four Pods — Every Woman Rotates Through All Four
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-nwprt-navy/15">
          {PODS.map((pod) => <PodCard {...pod} />)}
        </div>
        <p class="accent-italic text-sm text-nwprt-navy/60 mt-6">
          Spa Pass: 8 women per day, pre-selected at application · Thu 1–2:30PM · Fri 3:30–5PM · Sat 10:30AM–12PM · Sun 7:30–8:30AM
        </p>
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       6. WHAT YOU LEAVE WITH
       ═════════════════════════════════════════════════════════ */}
  <Section tone="navy" spacing="lg">
    <Container>
      <div class="scroll-reveal mb-12">
        <div class="caption text-nwprt-cream/50 mb-3">The takeaway</div>
        <h2 class="display text-4xl md:text-6xl mb-6">What You Leave With</h2>
        <div class="rule bg-nwprt-cream opacity-40"></div>
      </div>

      <div class="scroll-reveal grid md:grid-cols-3 gap-6">
        {LEAVE_WITH.map((card) => (
          <div class="border border-nwprt-cream/15 bg-nwprt-cream/[0.03] p-8">
            <h3 class="display text-2xl md:text-3xl mb-2 text-nwprt-cream">{card.title}</h3>
            <div class="accent-italic text-nwprt-cream/60 mb-5">{card.tag}</div>
            <p class="text-sm leading-relaxed text-nwprt-cream/70">{card.body}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       7. THE BRANDS
       ═════════════════════════════════════════════════════════ */}
  <Section tone="navy" spacing="lg" class="border-t border-nwprt-cream/10">
    <Container>
      <div class="scroll-reveal mb-12">
        <div class="caption text-nwprt-cream/50 mb-3">Behind the ritual</div>
        <h2 class="display text-4xl md:text-6xl mb-6">The Brands</h2>
        <div class="rule bg-nwprt-cream opacity-40"></div>
      </div>

      <div class="scroll-reveal grid md:grid-cols-3 gap-6">
        {BRANDS.map((card) => (
          <div class="border border-nwprt-cream/15 bg-nwprt-cream/[0.03] p-8">
            <h3 class="display text-2xl md:text-3xl mb-2 text-nwprt-cream">{card.title}</h3>
            <div class="accent-italic text-nwprt-cream/60 mb-5">{card.tag}</div>
            <p class="text-sm leading-relaxed text-nwprt-cream/70">{card.body}</p>
          </div>
        ))}
      </div>

      <div class="scroll-reveal mt-20 text-center">
        <div class="accent-italic text-xl md:text-2xl text-nwprt-cream/50 mb-8">The Journey</div>
        <div class="flex flex-wrap justify-center items-center gap-6 md:gap-8">
          {JOURNEY.map((step, i) => (
            <>
              <div class="text-center">
                <div class="display text-xl md:text-2xl text-nwprt-cream">{step.name}</div>
                <div class="caption text-nwprt-cream/50 mt-2">{step.sub}</div>
              </div>
              {i < JOURNEY.length - 1 && (
                <span class="accent-italic text-nwprt-cream/40 text-2xl">&rarr;</span>
              )}
            </>
          ))}
        </div>
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       8. WHY NEWPORT
       ═════════════════════════════════════════════════════════ */}
  <Section tone="cream" spacing="lg">
    <Container>
      <div class="scroll-reveal mb-12 max-w-2xl">
        <div class="caption text-nwprt-navy/50 mb-3">The setting</div>
        <h2 class="display text-4xl md:text-6xl text-nwprt-navy mb-6">Why Newport</h2>
        <div class="rule bg-nwprt-navy opacity-40 mb-8"></div>
        <p class="text-base md:text-lg text-nwprt-navy/70 leading-relaxed">
          Newport Beach isn&rsquo;t just a setting. It&rsquo;s a state of mind. One of the world&rsquo;s
          great small boat harbors. Eight miles of Pacific coastline. The kind of place that makes slowing
          down feel like the most natural thing in the world.
        </p>
      </div>

      <div class="scroll-reveal grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-nwprt-navy/15">
        {NEWPORT_CARDS.map((card) => (
          <div class="bg-nwprt-cream p-7">
            <h3 class="display text-xl md:text-2xl text-nwprt-navy mb-3">{card.title}</h3>
            <p class="text-sm leading-relaxed text-nwprt-navy/70">{card.body}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       9. THE INVESTMENT
       ═════════════════════════════════════════════════════════ */}
  <Section tone="off-white" spacing="lg">
    <Container>
      <div class="scroll-reveal mb-12">
        <div class="caption text-nwprt-navy/50 mb-3">The offering</div>
        <h2 class="display text-4xl md:text-6xl text-nwprt-navy mb-6">The Investment</h2>
        <div class="rule bg-nwprt-navy opacity-40 mb-8"></div>
        <p class="accent-italic text-lg text-nwprt-navy/70">
          All-inclusive. Nothing hidden. Everything intentional.
        </p>
      </div>

      <div class="scroll-reveal grid lg:grid-cols-3 gap-6">
        <PricingCard
          tier="Double Occupancy"
          price="$4,800"
          priceSub="per person · shared room"
          inclusions={DOUBLE_INCLUSIONS}
        />
        {/* Yellow moment #2 — the featured price earns the yellow. */}
        <PricingCard
          tier="Single Occupancy"
          price="$5,500"
          priceSub="per person · private room"
          inclusions={SINGLE_INCLUSIONS}
          featured
        />
        <PricingCard
          tier="Private Group"
          price="$85,000"
          priceSub="flat fee · 12 women · full buyout"
          inclusions={PRIVATE_INCLUSIONS}
          priceSize="md"
        />
      </div>

      <div class="scroll-reveal mt-12 p-8 bg-nwprt-cream grid md:grid-cols-2 gap-8">
        <div>
          <div class="caption text-nwprt-navy/60 mb-2">Optional add-on</div>
          <p class="text-sm text-nwprt-navy/75 leading-relaxed">
            Human Design or Astrology &mdash; $150&ndash;$250. Small group of 8&ndash;10. Reserved at application.
          </p>
        </div>
        <div>
          <div class="caption text-nwprt-navy/60 mb-2">How to apply</div>
          <p class="text-sm text-nwprt-navy/75 leading-relaxed">
            Short application + 15-minute call with Amy. Selection confirmed within 48 hours. Limited to 24 women.
          </p>
        </div>
      </div>
    </Container>
  </Section>

  {/* ══════════════════════════════════════════════════════════
       10. CLOSING CTA
       ═════════════════════════════════════════════════════════ */}
  <section class="relative bg-nwprt-navy text-nwprt-cream py-32 md:py-40 text-center overflow-hidden">
    <Container size="md" class="relative z-10">
      <div class="scroll-reveal">
        <div class="caption text-nwprt-yellow mb-8 tracking-[0.3em]">
          NWPRT Ritual · Newport Beach
        </div>

        <h2 class="accent-italic text-5xl md:text-7xl leading-[1.05] mb-8">
          Your tide<br />is turning.
        </h2>

        <div class="rule-yellow mx-auto my-10"></div>

        <p class="accent-italic text-lg md:text-xl text-nwprt-cream/60 mb-12">
          24 women. 4 days. One turning point.
        </p>

        {/* Yellow moment #3 — the earned payoff. */}
        <a
          href="https://gethalohealth.com/connect"
