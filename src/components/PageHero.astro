---
interface Props {
  eyebrow: string;
  title: string;
  tagline: string;
}

const { eyebrow, title, tagline } = Astro.props;
---

<section class="bg-nwprt-navy text-nwprt-cream py-20 md:py-28 text-center">
  <div class="max-w-5xl mx-auto w-full px-4 md:px-8 fade-in">
    <div class="caption text-nwprt-yellow mb-4">{eyebrow}</div>
    <h1 class="display text-5xl md:text-7xl text-nwprt-cream mb-6">{title}</h1>
    <div class="rule-yellow mx-auto mb-8"></div>
    <p class="accent-italic text-xl md:text-2xl text-nwprt-cream/80 max-w-2xl mx-auto">
      {tagline}
    </p>
  </div>
</section>
