---
interface Props {
  letter: string;
  name: string;
  lead: string;
  description: string;
}

const { letter, name, lead, description } = Astro.props;
---

<div class="bg-nwprt-off-white border border-nwprt-navy/10 p-6 md:p-7">
  <div class="caption text-nwprt-navy/50 mb-3">Pod {letter}</div>
  <div class="display text-xl md:text-2xl text-nwprt-navy mb-1">{name}</div>
  <div class="caption text-nwprt-navy/60 mb-4">{lead}</div>
  <p class="text-sm text-nwprt-navy/75 leading-relaxed">{description}</p>
</div>
