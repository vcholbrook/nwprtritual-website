---
import { Image } from 'astro:assets';
import heroBg from '../../assets/nwprt-lifestyle-1.jpg';
import heroLogo from '../../assets/nwprt-logo-navy.png';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-nwprt-navy text-nwprt-cream">
  {/* Background image with navy wash. fetchpriority="high" makes this
      the LCP candidate; Astro's pipeline emits a WebP-first srcset. */}
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-30"
      loading="eager"
      fetchpriority="high"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      format="webp"
      quality={70}
    />
    <div class="absolute inset-0 bg-nwprt-navy/60"></div>
  </div>

  {/* Content */}
  <div class="max-w-5xl mx-auto w-full px-4 md:px-8 relative z-10 text-center fade-in">
    <div class="caption text-nwprt-yellow mb-8">Newport Beach, California</div>

    <div class="flex justify-center mb-6 fade-in-scale">
      <Image
        src={heroLogo}
        alt="NWPRT"
        class="w-64 md:w-96 lg:w-[500px] h-auto opacity-50"
        widths={[256, 384, 500, 1000]}
        sizes="(min-width: 1024px) 500px, (min-width: 768px) 384px, 256px"
        format="webp"
        loading="eager"
      />
    </div>

    <div class="accent-italic text-3xl md:text-5xl lg:text-6xl text-nwprt-cream/90 mb-10">Ritual</div>

    <div class="rule-yellow mx-auto mb-12"></div>

    <p class="accent-italic text-xl md:text-2xl lg:text-3xl text-nwprt-cream/80 max-w-2xl mx-auto">
      Where Newport meets happiness, health, and longevity.
    </p>
  </div>
</section>
