---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-nwprt-navy text-nwprt-cream">
  {/* Background image with navy wash */}
  <div class="absolute inset-0">
    <img
      src="/nwprt-lifestyle-1.jpg"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-30"
      loading="eager"
    />
    <div class="absolute inset-0 bg-nwprt-navy/60"></div>
  </div>

  {/* Content */}
  <div class="max-w-5xl mx-auto w-full px-4 md:px-8 relative z-10 text-center fade-in">
    <div class="caption text-nwprt-yellow mb-8">Newport Beach, California</div>

    <div class="flex justify-center mb-6">
      <img
        src="/nwprt-logo.png"
        alt="NWPRT"
        class="w-64 md:w-96 lg:w-[500px] h-auto"
        width="583"
        height="180"
      />
    </div>

    <div class="accent-italic text-3xl md:text-5xl lg:text-6xl text-nwprt-cream/90 mb-10">Ritual</div>

    <div class="rule-yellow mx-auto mb-12"></div>

    <p class="accent-italic text-xl md:text-2xl lg:text-3xl text-nwprt-cream/80 max-w-2xl mx-auto">
      Where Newport meets happiness, health, and longevity.
    </p>
  </div>
</section>
