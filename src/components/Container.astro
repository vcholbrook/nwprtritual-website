---
/**
 * Horizontal content wrapper with consistent max-width + gutter.
 */
type Size = 'sm' | 'md' | 'lg' | 'xl';

interface Props {
  size?: Size;
  class?: string;
}

const { size = 'xl', class: className = '' } = Astro.props;

const widths: Record<Size, string> = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-6xl',
  xl: 'max-w-7xl',
};
---

<div class={`${widths[size]} mx-auto w-full px-4 md:px-8 ${className}`}>
  <slot />
</div>
